---
import Base from "../layouts/Base.astro";
import { Icon } from "astro-icon/components";
---

<Base title="dishape — lab (Three.js)" description="Entorno de prueba de experimentos 3D.">
  <main class="shell flex flex-col gap-16 py-16">
    <header class="flex flex-col gap-4">
      <a
        href="/"
        class="flex w-fit items-center gap-1.5 text-sm text-muted transition-colors hover:text-ink"
      >
        <Icon name="lucide:arrow-left" class="h-4 w-4" /> Volver al inicio
      </a>
      <span class="eyebrow">LAB / THREE.JS</span>
      <h1 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">
        Experimentos 3D
      </h1>
      <p class="max-w-2xl text-muted">
        Entorno aislado para evaluar el toque de Three.js sin afectar el sitio.
        Mové el mouse sobre cada escena. Respeta <code class="font-mono text-accent-light">prefers-reduced-motion</code>.
      </p>
    </header>

    <section class="flex flex-col gap-4">
      <h2 class="text-xl font-semibold text-ink">Variante A — Cubo dishape 3D</h2>
      <p class="max-w-2xl text-sm text-muted">
        El logo en volumen: rota lento y reacciona al mouse. Pensado para
        reemplazar (o convivir con) el panel de código en el hero.
      </p>
      <div
        class="relative aspect-[16/10] overflow-hidden rounded-2xl border border-line bg-card"
      >
        <canvas data-scene="cube" class="block h-full w-full"></canvas>
      </div>
    </section>

    <section class="flex flex-col gap-4">
      <h2 class="text-xl font-semibold text-ink">Variante B — Campo de cubos</h2>
      <p class="max-w-2xl text-sm text-muted">
        Fondo ambiental: cubos flotando con drift lento y parallax al mouse.
        Pensado como capa de fondo sutil en una sección (ej. Stack o IA).
      </p>
      <div
        class="relative aspect-[16/9] overflow-hidden rounded-2xl border border-line bg-base"
      >
        <canvas data-scene="field" class="block h-full w-full"></canvas>
      </div>
    </section>
  </main>

  <script>
    import "../scripts/lab";
  </script>
</Base>
