---
import Base from "../../layouts/Base.astro";
import BlogArticle from "../../components/BlogArticle.astro";
import { getCollection, render } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";

export const prerender = true;

export async function getStaticPaths() {
  const all = await getCollection("blog");
  return all
    .filter((p) => p.data.lang === "es")
    .map((post) => {
      const counterpart = all.find(
        (p) => p.data.lang === "en" && p.data.translationKey === post.data.translationKey,
      );
      return {
        params: { slug: post.data.slug },
        props: { post, enSlug: counterpart?.data.slug },
      };
    });
}

const { post, enSlug } = Astro.props;
const { Content } = await render(post);
const alternates = {
  es: getRelativeLocaleUrl("es", `blog/${post.data.slug}`),
  // Only declare the EN hreflang when a real counterpart exists — pointing at
  // the blog index would break reciprocity and get the pair dropped.
  en: enSlug ? getRelativeLocaleUrl("en", `blog/${enSlug}`) : undefined,
};
const article = {
  publishedTime: post.data.pubDate.toISOString(),
  headline: post.data.title,
};
---

<Base
  title={`${post.data.title} | dishape`}
  description={post.data.description}
  alternates={alternates}
  ogType="article"
  article={article}
>
  <BlogArticle post={post}>
    <Content />
  </BlogArticle>
</Base>
