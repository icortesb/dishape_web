---
import SectionHeader from "./SectionHeader.astro";
import { Icon } from "astro-icon/components";
import { getLang, getDict } from "../i18n";
import { SITE, waLink } from "../site";

const lang = getLang(Astro);
const t = getDict(lang).contact;

const field =
  "w-full rounded-lg border border-line bg-card px-4 py-3 text-sm text-ink placeholder:text-faint transition-colors focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent";
const label = "mb-2 block text-sm font-medium text-muted";
---

<section
  id="contacto"
  class="relative scroll-mt-20 overflow-hidden border-b border-line bg-base"
>
  <div
    class="blueprint-grid pointer-events-none absolute inset-x-0 -top-[40%] h-[180%]"
    style="--grid-color: rgb(255 255 255 / 0.035)"
    data-parallax="0.25"
  >
  </div>

  <div class="shell relative flex flex-col gap-14 py-24">
    <SectionHeader eyebrow={t.eyebrow} title={t.title}>
      <p class="text-lg leading-relaxed text-muted">{t.intro}</p>
    </SectionHeader>

    <div class="grid gap-12 lg:grid-cols-[1.4fr_1fr]">
      <form
        class="reveal grid gap-5"
        data-contact-form
        method="POST"
        action="/api/contact"
        data-lang={lang}
        data-sending={t.form.sending}
        data-success={t.form.success}
        data-error={t.form.error}
      >
        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <label class={label} for="name">{t.form.name}</label>
            <input class={field} id="name" name="name" type="text" placeholder={t.form.namePh} required />
          </div>
          <div>
            <label class={label} for="email">{t.form.email}</label>
            <input class={field} id="email" name="email" type="email" placeholder={t.form.emailPh} required />
          </div>
        </div>
        <div>
          <label class={label} for="company">{t.form.company}</label>
          <input class={field} id="company" name="company" type="text" placeholder={t.form.companyPh} />
        </div>
        <div>
          <label class={label} for="message">{t.form.message}</label>
          <textarea class={`${field} min-h-36 resize-y`} id="message" name="message" placeholder={t.form.messagePh} required></textarea>
        </div>

        <!-- honeypot: hidden from humans, bots tend to fill it -->
        <input
          type="text"
          name="website"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
          class="absolute -left-[9999px] h-0 w-0 opacity-0"
        />

        <button
          type="submit"
          class="rounded-lg bg-accent px-6 py-3.5 font-semibold text-white shadow-lg shadow-accent/20 transition-transform hover:-translate-y-0.5 disabled:cursor-not-allowed disabled:opacity-60"
        >
          {t.form.submit}
        </button>

        <p
          data-form-status
          role="status"
          aria-live="polite"
          class="hidden text-sm"
        >
        </p>
      </form>

      <aside class="reveal flex flex-col gap-5">
        <h3 class="text-xl font-semibold text-ink">{t.asideTitle}</h3>
        <p class="text-sm leading-relaxed text-muted">{t.asideBody}</p>

        <a
          href={SITE.calendly}
          target="_blank"
          rel="noopener noreferrer"
          data-calendly
          class="flex items-center gap-3 rounded-xl border border-line bg-card p-4 transition-colors hover:border-accent/30"
        >
          <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-accent/12">
            <Icon name="lucide:calendar-clock" class="h-5 w-5 text-accent-light" />
          </span>
          <span>
            <span class="block text-xs text-faint">{t.calendlyLabel}</span>
            <span class="text-sm text-ink">{t.calendlyValue}</span>
          </span>
        </a>

        <a
          href={`mailto:${SITE.email}`}
          class="flex items-center gap-3 rounded-xl border border-line bg-card p-4 transition-colors hover:border-accent/30"
        >
          <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-accent/12">
            <Icon name="lucide:mail" class="h-5 w-5 text-accent-light" />
          </span>
          <span>
            <span class="block text-xs text-faint">{t.emailLabel}</span>
            <span class="text-sm text-ink">{SITE.email}</span>
          </span>
        </a>

        <a
          href={waLink(t.whatsappPrefill)}
          target="_blank"
          rel="noopener noreferrer"
          data-wa-link
          class="flex items-center gap-3 rounded-xl border border-line bg-card p-4 transition-colors hover:border-accent/30"
        >
          <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-accent/12">
            <Icon name="lucide:message-circle" class="h-5 w-5 text-accent-light" />
          </span>
          <span>
            <span class="block text-xs text-faint">{t.whatsappLabel}</span>
            <span class="text-sm text-ink">{SITE.whatsappDisplay}</span>
          </span>
        </a>

        <div class="flex items-center gap-2 rounded-xl border border-line bg-card/50 p-4">
          <Icon name="lucide:clock" class="h-4 w-4 text-accent-light" />
          <span class="text-sm text-muted">{t.responseTime}</span>
        </div>
      </aside>
    </div>
  </div>
</section>

<script>
  import "../scripts/contact";
</script>
