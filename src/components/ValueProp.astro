---
import SectionHeader from "./SectionHeader.astro";
import Card from "./Card.astro";
import { getLang, getDict } from "../i18n";

const t = getDict(getLang(Astro)).value;
---

<section class="border-b border-line bg-base">
  <div class="shell flex flex-col gap-14 py-24">
    <SectionHeader eyebrow={t.eyebrow} title={t.title}>
      <p class="text-lg leading-relaxed text-muted">{t.intro}</p>
    </SectionHeader>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        t.items.map(([icon, title, body]) => (
          <Card icon={icon} title={title}>
            {body}
          </Card>
        ))
      }
    </div>
  </div>
</section>
