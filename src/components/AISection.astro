---
import SectionHeader from "./SectionHeader.astro";
import Card from "./Card.astro";
import CubeField from "./CubeField.astro";
import { getLang, getDict } from "../i18n";

const t = getDict(getLang(Astro)).ai;
---

<section
  id="ia"
  class="relative scroll-mt-20 overflow-hidden border-b border-line bg-base"
>
  <CubeField />
  <div class="shell relative z-10 flex flex-col gap-14 py-24">
    <SectionHeader eyebrow={t.eyebrow} title={t.title}>
      <p class="max-w-2xl text-lg leading-relaxed text-muted">{t.intro}</p>
    </SectionHeader>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        t.items.map(([icon, title, body]) => (
          <Card icon={icon} title={title}>
            {body}
          </Card>
        ))
      }
    </div>
  </div>
</section>
