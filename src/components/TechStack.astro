---
import SectionHeader from "./SectionHeader.astro";
import { getLang, getDict } from "../i18n";

const t = getDict(getLang(Astro)).stack;
const groups = t.groups as readonly (readonly [string, readonly string[]])[];
---

<section id="stack" class="scroll-mt-20 border-b border-line bg-base">
  <div class="shell flex flex-col gap-14 py-24">
    <SectionHeader eyebrow={t.eyebrow} title={t.title}>
      <p class="text-lg leading-relaxed text-muted">{t.intro}</p>
    </SectionHeader>

    <div class="grid gap-6 md:grid-cols-2">
      {
        groups.map(([name, items], i) => (
          <div
            class:list={[
              "reveal rounded-2xl border border-line bg-card p-8",
              i === groups.length - 1 && "md:col-span-2",
            ]}
          >
            <h3 class="eyebrow mb-5">{name}</h3>
            <ul class="flex flex-wrap gap-2.5">
              {items.map((t) => (
                <li class="rounded-full border border-line bg-elevated px-4 py-2 text-[13px] font-medium text-ink">
                  {t}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
