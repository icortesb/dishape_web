---
import LogoMark from "./LogoMark.astro";
import Wordmark from "./Wordmark.astro";
import { getRelativeLocaleUrl } from "astro:i18n";
import { getLang, getDict, languages, type Lang } from "../i18n";
import { SITE } from "../site";

const lang = getLang(Astro);
const t = getDict(lang).nav;
const home = getRelativeLocaleUrl(lang, "");

const links = [
  { label: t.services, href: `${home}#servicios` },
  { label: t.ai, href: `${home}#ia` },
  { label: t.process, href: `${home}#proceso` },
  { label: t.stack, href: `${home}#stack` },
  { label: t.blog, href: getRelativeLocaleUrl(lang, "blog") },
  { label: t.contact, href: `${home}#contacto` },
];

const other: Lang = lang === "es" ? "en" : "es";
const otherUrl = getRelativeLocaleUrl(other, "");
---

<header class="sticky top-0 z-50 border-b border-line bg-base/80 backdrop-blur-md">
  <nav class="shell flex items-center justify-between py-4">
    <a href={home} class="flex items-center gap-2.5" aria-label="dishape — inicio">
      <LogoMark class="h-8 w-8" cut="#0a0a0f" />
      <Wordmark class="text-xl" />
    </a>

    <ul class="hidden items-center gap-8 md:flex">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-sm font-medium text-muted transition-colors hover:text-ink"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-3">
      <a
        href={otherUrl}
        hreflang={other}
        data-set-lang={other}
        class="rounded-md border border-line px-2.5 py-1.5 text-xs font-semibold text-muted transition-colors hover:border-accent/40 hover:text-ink"
        aria-label={`Switch to ${languages[other]}`}
      >
        {languages[other]}
      </a>
      <a
        href={SITE.calendly}
        target="_blank"
        rel="noopener noreferrer"
        data-calendly
        data-cta="navbar_book"
        class="rounded-lg bg-accent px-5 py-2.5 text-sm font-semibold text-white transition-transform hover:-translate-y-0.5"
      >
        {t.book}
      </a>
    </div>
  </nav>
</header>

<script is:inline>
  // Persist the chosen language the instant the toggle is clicked, BEFORE the
  // browser navigates. Otherwise the request for "/" still carries the old
  // lang cookie and the nginx edge redirect bounces the visitor back to their
  // previous language (EN->ES never reaches Spanish).
  document.addEventListener("click", function (e) {
    var a = e.target.closest && e.target.closest("[data-set-lang]");
    if (!a) return;
    var l = a.getAttribute("data-set-lang");
    document.cookie = "lang=" + l + "; path=/; max-age=31536000; samesite=lax";
  });
</script>
