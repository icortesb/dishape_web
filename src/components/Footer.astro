---
import LogoMark from "./LogoMark.astro";
import Wordmark from "./Wordmark.astro";
import { Icon } from "astro-icon/components";
import { getLang, getDict } from "../i18n";
import { SITE, waLink } from "../site";

const lang = getLang(Astro);
const nav = getDict(lang).nav;
const t = getDict(lang).footer;

const links = [
  { label: nav.services, href: "#servicios" },
  { label: nav.ai, href: "#ia" },
  { label: nav.process, href: "#proceso" },
  { label: nav.stack, href: "#stack" },
  { label: nav.benefits, href: "#resultados" },
  { label: nav.contact, href: "#contacto" },
];

const social = [
  { icon: "github", href: SITE.social.github, label: "GitHub" },
  { icon: "linkedin", href: SITE.social.linkedin, label: "LinkedIn" },
  { icon: "message-circle", href: waLink(), label: "WhatsApp" },
  { icon: "mail", href: `mailto:${SITE.email}`, label: "Email" },
];

const year = new Date().getFullYear();
---

<footer class="bg-base">
  <div class="shell flex flex-col gap-8 py-12">
    <div class="flex flex-col justify-between gap-8 md:flex-row md:items-start">
      <div class="flex max-w-xs flex-col gap-3">
        <div class="flex items-center gap-2.5">
          <LogoMark class="h-7 w-7" />
          <Wordmark class="text-lg" />
        </div>
        <p class="text-sm leading-relaxed text-faint">{t.tagline}</p>
      </div>

      <ul class="flex flex-wrap gap-x-8 gap-y-3">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm font-medium text-muted transition-colors hover:text-ink"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>

      <div class="flex items-center gap-3">
        {
          social.map((s) => (
            <a
              href={s.href}
              aria-label={s.label}
              target="_blank"
              rel="noopener noreferrer"
              class="flex h-9 w-9 items-center justify-center rounded-lg border border-line text-muted transition-colors hover:border-accent/30 hover:text-ink"
            >
              <Icon name={`lucide:${s.icon}`} class="h-4 w-4" />
            </a>
          ))
        }
      </div>
    </div>

    <div class="h-px w-full bg-line"></div>

    <div class="flex flex-col justify-between gap-2 text-sm text-faint sm:flex-row sm:items-center">
      <span>© {year} {SITE.name} — {t.rights}</span>
      <a href={`mailto:${SITE.email}`} class="transition-colors hover:text-ink">{SITE.email}</a>
    </div>
  </div>
</footer>
