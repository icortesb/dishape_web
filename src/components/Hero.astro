---
const flowLines = [
  ["diseño", "interfaces UI/UX"],
  ["desarrollo", "frontend + backend"],
  ["datos", "SQL / NoSQL"],
  ["infra", "deploy · hosting · mails"],
  ["analítica", "GA4 / GTM"],
  ["conversión", "SEO · CRO · performance"],
];
---

<section id="top" class="relative overflow-hidden border-b border-line bg-base">
  <!-- blueprint grid + glow -->
  <div
    class="blueprint-grid pointer-events-none absolute inset-x-0 -top-[40%] h-[180%]"
    data-parallax="0.3"
  >
  </div>
  <div
    class="pointer-events-none absolute -top-24 right-[8%] h-[500px] w-[500px] rounded-full opacity-60"
    style="background: radial-gradient(circle, rgba(63,185,80,0.10), transparent 70%)"
    data-parallax="-0.25"
  >
  </div>

  <div
    class="shell relative grid items-center gap-16 py-24 lg:grid-cols-[1.1fr_0.9fr] lg:py-28"
  >
    <!-- copy -->
    <div class="flex flex-col items-start gap-7">
      <span class="eyebrow reveal flex items-center gap-2">
        <span class="h-2 w-2 rounded-full bg-accent"></span>
        DISPONIBLE PARA NUEVOS PROYECTOS
      </span>
      <h1
        class="reveal text-4xl font-bold leading-[1.08] tracking-tight text-ink sm:text-5xl lg:text-[3.4rem]"
      >
        Tu proyecto web, de la idea al deploy — con un solo responsable técnico.
      </h1>
      <p class="reveal max-w-xl text-lg leading-relaxed text-muted">
        Diseño, desarrollo, bases de datos, infraestructura, integraciones y
        analítica. Una sola persona senior que entiende el negocio y responde
        por los números.
      </p>
      <div class="reveal flex flex-wrap gap-4">
        <a
          href="#contacto"
          class="rounded-lg bg-accent px-8 py-4 font-semibold text-white shadow-lg shadow-accent/20 transition-transform hover:-translate-y-0.5"
        >
          Hablemos de tu proyecto
        </a>
        <a
          href="#servicios"
          class="rounded-lg border border-line px-8 py-4 font-medium text-muted transition-colors hover:border-accent/40 hover:text-ink"
        >
          Ver servicios
        </a>
      </div>
    </div>

    <!-- code / flow panel -->
    <div
      class="reveal w-full overflow-hidden rounded-2xl border border-line bg-card shadow-2xl shadow-black/40"
    >
      <div class="flex items-center gap-2 border-b border-line bg-elevated px-4 py-3.5">
        <span class="h-2.5 w-2.5 rounded-full" style="background:#ff5f56"></span>
        <span class="h-2.5 w-2.5 rounded-full" style="background:#ffbd2e"></span>
        <span class="h-2.5 w-2.5 rounded-full" style="background:#27c93f"></span>
        <span class="ml-2 font-mono text-xs text-faint">flujo.ts</span>
      </div>
      <div class="p-6 font-mono text-[13px] leading-loose">
        <p class="text-faint">// lo que entrego, de punta a punta</p>
        {
          flowLines.map(([k, v]) => (
            <p class="flex text-muted">
              <span class="inline-block w-28 shrink-0 text-accent-light">{k}</span>
              <span class="mr-2 text-faint">&rarr;</span>
              {v}
            </p>
          ))
        }
      </div>
    </div>
  </div>
</section>
