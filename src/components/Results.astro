---
import SectionHeader from "./SectionHeader.astro";
import Card from "./Card.astro";
import { getLang, getDict } from "../i18n";

const t = getDict(getLang(Astro)).results;
---

<section id="resultados" class="scroll-mt-20 border-b border-line bg-surface">
  <div class="shell flex flex-col gap-14 py-24">
    <SectionHeader eyebrow={t.eyebrow} title={t.title}>
      <p class="max-w-2xl text-lg leading-relaxed text-muted">{t.intro}</p>
    </SectionHeader>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        t.items.map(([icon, title, body]) => (
          <Card icon={icon} title={title}>
            {body}
          </Card>
        ))
      }
    </div>

    <div class="reveal flex justify-center pt-4">
      <a
        href="#contacto"
        class="rounded-lg bg-accent px-10 py-4 font-semibold text-white shadow-lg shadow-accent/20 transition-transform hover:-translate-y-0.5"
      >
        {t.cta}
      </a>
    </div>
  </div>
</section>
