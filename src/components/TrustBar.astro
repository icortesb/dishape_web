---
// Métricas ilustrativas — reemplazar por números reales antes de publicar.
const metrics = [
  { prefix: "+", count: 40, suffix: "%", label: "conversión promedio" },
  { prefix: "−", count: 55, suffix: "%", label: "tiempo de carga" },
  { prefix: "", count: 95, suffix: "+", label: "Core Web Vitals" },
  { prefix: "+", count: 35, suffix: "%", label: "tráfico orgánico (SEO)" },
];
---

<section class="border-b border-line bg-surface">
  <div class="shell grid grid-cols-2 gap-8 py-9 md:grid-cols-4">
    {
      metrics.map((m) => (
        <div class="reveal flex flex-col gap-1.5">
          <span
            class="text-3xl font-bold text-accent-light"
            data-count={m.count}
            data-prefix={m.prefix}
            data-suffix={m.suffix}
          >
            {m.prefix}
            {m.count}
            {m.suffix}
          </span>
          <span class="font-mono text-xs text-faint">{m.label}</span>
        </div>
      ))
    }
  </div>
</section>
