---
interface Props {
  eyebrow: string;
  title: string;
}
const { eyebrow, title } = Astro.props;
---

<div class="reveal flex max-w-3xl flex-col items-start gap-4">
  <span class="eyebrow">{eyebrow}</span>
  <h2 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">{title}</h2>
  <slot />
</div>
