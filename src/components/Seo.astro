---
import { getRelativeLocaleUrl } from "astro:i18n";
import { getLang, getDict } from "../i18n";
import { SITE } from "../site";

interface Props {
  title: string;
  description: string;
  image?: string;
}
const { title, description, image = "/og.png" } = Astro.props;
const lang = getLang(Astro);

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;

const alternates = [
  { hreflang: "es", href: new URL(getRelativeLocaleUrl("es", ""), Astro.site).href },
  { hreflang: "en", href: new URL(getRelativeLocaleUrl("en", ""), Astro.site).href },
  { hreflang: "x-default", href: new URL(getRelativeLocaleUrl("es", ""), Astro.site).href },
];

const ogLocale = lang === "es" ? "es_AR" : "en_US";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: SITE.name,
  description: getDict(lang).meta.description,
  url: SITE.url,
  image: ogImage,
  email: SITE.email,
  telephone: `+${SITE.whatsapp}`,
  priceRange: "$$",
  areaServed: ["AR", "Latin America", "Worldwide"],
  knowsLanguage: ["es", "en"],
};
---

<link rel="canonical" href={canonical} />
{alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}

<meta name="description" content={description} />
<meta name="robots" content="index, follow, max-image-preview:large" />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />
<meta property="og:locale" content={ogLocale} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={title} />

<script
  type="application/ld+json"
  is:inline
  set:html={JSON.stringify(jsonLd)}
/>
