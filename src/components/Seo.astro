---
import { getRelativeLocaleUrl } from "astro:i18n";
import { getLang, getDict } from "../i18n";
import { SITE } from "../site";

interface Props {
  title: string;
  description: string;
  image?: string;
  /**
   * Localized paths for the ES/EN counterparts of this page (defaults to home).
   * Omit `en` to skip the English hreflang (e.g. an ES-only post with no
   * counterpart — pointing it at the blog index would break reciprocity).
   */
  alternates?: { es: string; en?: string };
  /** Open Graph type. "article" for blog posts, "website" otherwise. */
  ogType?: "website" | "article";
  /** When present, emit BlogPosting (article) schema instead of ProfessionalService. */
  article?: { publishedTime: string; headline: string };
}
const {
  title,
  description,
  image,
  alternates: altPaths,
  ogType = "website",
  article,
} = Astro.props;
const lang = getLang(Astro);

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image ?? (lang === "en" ? "/og-en.png" : "/og.png"), Astro.site).href;

const paths = altPaths ?? {
  es: getRelativeLocaleUrl("es", ""),
  en: getRelativeLocaleUrl("en", ""),
};
const alternates = [
  { hreflang: "es", href: new URL(paths.es, Astro.site).href },
  ...(paths.en ? [{ hreflang: "en", href: new URL(paths.en, Astro.site).href }] : []),
  { hreflang: "x-default", href: new URL(paths.es, Astro.site).href },
];

const ogLocale = lang === "es" ? "es_AR" : "en_US";

const author = {
  "@type": "Person",
  name: SITE.author,
  sameAs: [SITE.social.github, SITE.social.linkedin],
};

const jsonLd = article
  ? {
      "@context": "https://schema.org",
      "@type": "BlogPosting",
      headline: article.headline,
      description,
      image: ogImage,
      datePublished: article.publishedTime,
      dateModified: article.publishedTime,
      inLanguage: lang,
      mainEntityOfPage: canonical,
      author,
      publisher: {
        "@type": "Organization",
        name: SITE.name,
        url: SITE.url,
      },
    }
  : {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      name: SITE.name,
      description: getDict(lang).meta.description,
      url: SITE.url,
      image: ogImage,
      email: SITE.email,
      telephone: `+${SITE.whatsapp}`,
      priceRange: "$$",
      areaServed: ["AR", "Latin America", "Worldwide"],
      knowsLanguage: ["es", "en"],
      sameAs: [SITE.social.github, SITE.social.linkedin],
    };
---

<link rel="canonical" href={canonical} />
{alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}

<meta name="description" content={description} />
<meta name="robots" content="index, follow, max-image-preview:large" />

{/* Open Graph */}
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />
<meta property="og:locale" content={ogLocale} />
{
  article && (
    <>
      <meta property="article:published_time" content={article.publishedTime} />
      <meta property="article:author" content={SITE.author} />
    </>
  )
}

{/* Twitter */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={title} />

<script
  type="application/ld+json"
  is:inline
  set:html={JSON.stringify(jsonLd)}
/>
