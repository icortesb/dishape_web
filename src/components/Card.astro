---
import { Icon } from "astro-icon/components";

interface Props {
  icon: string;
  title: string;
}
const { icon, title } = Astro.props;
---

<article
  class="reveal flex h-full flex-col gap-4 rounded-2xl border border-line bg-card p-7 transition-colors duration-300 hover:border-accent/30 hover:bg-card-hover"
>
  <span class="flex h-12 w-12 items-center justify-center rounded-lg bg-accent/12">
    <Icon name={`lucide:${icon}`} class="h-6 w-6 text-accent-light" />
  </span>
  <h3 class="text-lg font-semibold text-ink">{title}</h3>
  <p class="text-sm leading-relaxed text-muted"><slot /></p>
</article>
