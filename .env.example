# ── Email (contact form → Resend) ────────────────────────────────
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Verified sender on your domain (set up domain + DKIM in Resend first).
# Until the domain is verified you can use onboarding@resend.dev for testing.
CONTACT_FROM="dishape <no-reply@dishape.dev>"
# Where contact submissions are delivered.
CONTACT_TO=dishape.dev@gmail.com

# ── Analytics (all optional — left blank = tag simply not injected) ─
# Google Tag Manager container (manages GA4, Meta Pixel & Clarity inside GTM).
PUBLIC_GTM_ID=

# ── Server (Node standalone build) ───────────────────────────────
HOST=0.0.0.0
PORT=4321
